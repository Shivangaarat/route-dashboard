# ── Neon Postgres (get this from your Neon dashboard → Connection string) ─
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Mailbox (IMAP) ────────────────────────────────────────────────────────
# Gmail: use an App Password — Google Account → Security → App Passwords
MAIL_HOST=imap.gmail.com
MAIL_PORT=993
MAIL_USER=dispatch-data@yourdomain.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Security ──────────────────────────────────────────────────────────────
# Any long random string — protects the cron endpoint from outside calls
CRON_SECRET=replace-with-any-long-random-string

# ── Email subject filter ──────────────────────────────────────────────────
# Only process emails whose subject contains this string
MAIL_SUBJECT_FILTER=Dispatch Report
